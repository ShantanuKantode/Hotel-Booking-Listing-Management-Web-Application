<!DOCTYPE html>
<html lang="en">
<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>WanderLust</title>
</head>
<body>
   <h3>Create New Listing</h3>
   <form method="POST"action="/listings">
      <input name="listing[title]" placeholder="Title" type="text" >
      <br><br>
      <input name="listing[description]" placeholder="description" type="textarea">
      <br><br>
      <input name="listing[image]" placeholder="image URL" type="text">
      <br><br>
      <input name="listing[price]"  placeholder="price" type="number">
      <br><br>
      <input name="listing[location]" placeholder="location" type="text">
      <br><br>
      <input type="text" name="listing[country]" placeholder="country">
       
      <button >Add</button>
   </form>
</body>
</html>